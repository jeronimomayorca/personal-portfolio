  <text
    x="55"
    y="315"
    font-family="monospace"
    font-size="11"
    fill="var(--color-text-secondary, #666)">deployment progress</text
  >
  <text
    x="380"
    y="315"
    text-anchor="end"
    font-family="monospace"
    font-size="10"
    fill="#ff5f56">~forever</text
  >
  <rect
    x="55"
    y="322"
    width="330"
    height="10"
    rx="5"
    fill="var(--color-background-tertiary, #e8e8e8)"></rect>
  <rect
    class="aw-progress"
    x="55"
    y="322"
    width="0"
    height="10"
    rx="5"
    fill="#534AB7"></rect>
  <!-- ping dot -->
  <circle cx="55" cy="350" r="4" fill="#27c93f"></circle>
  <circle class="aw-ping" cx="55" cy="350" r="4" fill="#27c93f" opacity="0.4"
  ></circle>
  <text
    x="67"
    y="354"
    font-family="monospace"
    font-size="10"
    fill="var(--color-text-secondary, #666)"
  >
    agente trabajando... uptime: 4d 17h 32m
  </text>

  <!-- ── Main message ─────────────────────────────────────── -->
  <text
    x="340"
    y="498"
    text-anchor="middle"
    font-family="sans-serif"
    font-size="14"
    font-weight="500"
    fill="var(--color-text-secondary, #666)"
  >
    nuestro agente está trabajando al máximo de su capacidad
  </text>
  <text
    x="340"
    y="518"
    text-anchor="middle"
    font-family="sans-serif"
    font-size="13"
    fill="var(--color-text-secondary, #666)"
  >
    para tener lista esta sección pronto
  </text>
  <text
    x="340"
    y="540"
    text-anchor="middle"
    font-family="monospace"
    font-size="11"
    fill="var(--color-text-tertiary, #aaa)"
  >
    (definición de "pronto" sujeta a disponibilidad de café y karma de Jenkins)
  </text>
</svg>
