---

---

<style is:global>
  @keyframes aw-cursor {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }
  @keyframes aw-coffeesteam {
    0%,
    100% {
      opacity: 0;
      transform: translate(0, 0) scaleX(1);
    }
    50% {
      opacity: 0.6;
      /* Movimiento más exagerado para que se note el cambio */
      transform: translate(10px, -25px) scaleX(1.3);
    }
  }
  @keyframes aw-progress {
    0% {
      width: 0px;
    }
    30% {
      width: 180px;
    }
    31% {
      width: 0px;
    }
    60% {
      width: 120px;
    }
    61% {
      width: 0px;
    }
    90% {
      width: 240px;
    }
    100% {
      width: 240px;
    }
  }
  @keyframes aw-ping {
    0% {
      r: 4;
      opacity: 1;
    }
    100% {
      r: 14;
      opacity: 0;
    }
  }
  @keyframes aw-scrollcode {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-120px);
    }
  }

  .aw-cursor {
    animation: aw-cursor 1s step-end infinite;
  }
  .aw-steam1 {
    animation: aw-coffeesteam 1.8s ease-in-out infinite 0s;
    transform-box: fill-box;
    transform-origin: bottom;
  }
  .aw-steam2 {
    animation: aw-coffeesteam 1.8s ease-in-out infinite 0.6s;
    transform-box: fill-box;
    transform-origin: bottom;
  }
  .aw-steam3 {
    animation: aw-coffeesteam 1.8s ease-in-out infinite 1.2s;
    transform-box: fill-box;
    transform-origin: bottom;
  }
  .aw-progress {
    animation: aw-progress 8s ease-out infinite;
  }
  .aw-ping {
    animation: aw-ping 1.5s ease-out infinite;
  }
  .aw-scrollcode {
    animation: aw-scrollcode 6s linear infinite;
  }
</style>

<svg
  width="100%"
  viewBox="0 0 680 560"
  role="img"
  xmlns="http://www.w3.org/2000/svg"
  class="absolute inset-0 w-full h-full object-contain pt-24 pointer-events-none"
  aria-label="Agente trabajando en esta sección"
>
  <title>404 - Agente trabajando</title>
  <desc
    >Un desarrollador senior lidiando con un error 404 con humor negro técnico</desc
  >

  <defs>
    <marker
      id="arrow"
      viewBox="0 0 10 10"
      refX="8"
      refY="5"
      markerWidth="6"
      markerHeight="6"
      orient="auto-start-reverse"
    >
      <path
        d="M2 1L8 5L2 9"
        fill="none"
        stroke="context-stroke"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </marker>
    <clipPath id="termclip">
      <rect x="40" y="58" width="360" height="212"></rect>
    </clipPath>
  </defs>

  <!-- ── Terminal window ─────────────────────────────────── -->
  <rect x="40" y="30" width="360" height="240" rx="10" fill="#1a1a1a"></rect>
  <!-- titlebar -->
  <rect x="40" y="30" width="360" height="28" rx="10" fill="#2d2d2d"></rect>
  <rect x="40" y="44" width="360" height="14" fill="#2d2d2d"></rect>
  <!-- traffic lights -->
  <circle cx="60" cy="44" r="5" fill="#ff5f56"></circle>
  <circle cx="76" cy="44" r="5" fill="#ffbd2e"></circle>
  <circle cx="92" cy="44" r="5" fill="#27c93f"></circle>
  <text
    x="220"
    y="49"
    text-anchor="middle"
    font-family="monospace"
    font-size="11"
    fill="#888"
  >
    bash — production-server — 80x24
  </text>

  <!-- scrolling code -->
  <g clip-path="url(#termclip)">
    <g class="aw-scrollcode">
      <text x="55" y="80" font-family="monospace" font-size="11" fill="#27c93f"
        >$ git push origin main --force</text
      >
      <text x="55" y="96" font-family="monospace" font-size="11" fill="#888"
        >Counting objects: 847, done.</text
      >
      <text x="55" y="112" font-family="monospace" font-size="11" fill="#ff5f56"
        >ERROR: pre-receive hook declined</text
      >
      <text x="55" y="128" font-family="monospace" font-size="11" fill="#888"
        >$ sudo rm -rf node_modules</text
      >
      <text x="55" y="144" font-family="monospace" font-size="11" fill="#888"
        >$ npm install</text
      >
      <text x="55" y="160" font-family="monospace" font-size="11" fill="#ffbd2e"
        >added 2,847 packages in 4m</text
      >
      <text x="55" y="176" font-family="monospace" font-size="11" fill="#ff5f56"
        >FATAL: cannot allocate memory</text
      >
      <text x="55" y="192" font-family="monospace" font-size="11" fill="#888"
        >$ kill -9 $(lsof -t -i:3000)</text
      >
      <text x="55" y="208" font-family="monospace" font-size="11" fill="#27c93f"
        >$ npm run build</text
      >
      <text x="55" y="224" font-family="monospace" font-size="11" fill="#ffbd2e"
        >webpack 5.88.0 compiling...</text
      >
      <text x="55" y="240" font-family="monospace" font-size="11" fill="#ff5f56"
        >Module not found: './utils/404'</text
      >
      <text x="55" y="256" font-family="monospace" font-size="11" fill="#888"
        >$ git blame index.js</text
      >
      <text x="55" y="272" font-family="monospace" font-size="11" fill="#888"
        >a3f91cc (pedro 3 years ago) // temp</text
      >
    </g>
  </g>

  <!-- static prompt -->
  <rect x="40" y="248" width="360" height="22" fill="#1a1a1a"></rect>
  <text x="55" y="263" font-family="monospace" font-size="11" fill="#27c93f">
    $ <tspan class="aw-cursor">▋</tspan>
  </text>

  <!-- ── Post-it ──────────────────────────────────────────── -->
  <rect
    x="440"
    y="30"
    width="200"
    height="130"
    rx="3"
    fill="#ffef9f"
    stroke="#e8d840"
    stroke-width="0.5"></rect>
  <text
    x="450"
    y="52"
    font-family="monospace"
    font-size="10"
    fill="#333"
    font-weight="500">TODO (crítico):</text
  >
  <text x="450" y="68" font-family="monospace" font-size="10" fill="#555"
    >- fix the thing</text
  >
  <text x="450" y="82" font-family="monospace" font-size="10" fill="#555"
    >- revert the fix</text
  >
  <text x="450" y="96" font-family="monospace" font-size="10" fill="#555"
    >- fix the revert</text
  >
  <text
    x="450"
    y="110"
    font-family="monospace"
    font-size="10"
    fill="#c00"
    font-weight="500">- NO TOCAR PROD</text
  >
  <text
    x="450"
    y="124"
    font-family="monospace"
    font-size="10"
    fill="#c00"
    font-weight="500"
  >
    HASTA EL LUNES</text
  >
  <text x="450" y="138" font-family="monospace" font-size="9" fill="#888"
    >* lunes de 2019</text
  >

  <!-- ── Coffee cup ───────────────────────────────────────── -->
  <g transform="translate(0, 30)">
    <rect x="550" y="195" width="50" height="40" rx="4" fill="#6f4e37"></rect>
    <rect x="553" y="198" width="44" height="34" rx="3" fill="#8B6347"></rect>
    <rect x="553" y="198" width="44" height="12" rx="3" fill="#3d2010"></rect>
    <text
      x="575"
      y="209"
      text-anchor="middle"
      font-family="monospace"
      font-size="8"
      fill="#ffbd2e">404</text
    >
    <path
      d="M600 210 Q610 210 610 218 Q610 226 600 226"
      fill="none"
      stroke="#6f4e37"
      stroke-width="3"
      stroke-linecap="round"></path>
    <rect x="548" y="234" width="60" height="4" rx="1" fill="#6f4e37"></rect>
    <!-- steam -->
    <path
      class="aw-steam1"
      d="M563 194 Q566 188 563 182"
      fill="none"
      stroke="#aaa"
      stroke-width="1.5"
      stroke-linecap="round"></path>
    <path
      class="aw-steam2"
      d="M572 194 Q575 187 572 180"
      fill="none"
      stroke="#aaa"
      stroke-width="1.5"
      stroke-linecap="round"></path>
    <path
      class="aw-steam3"
      d="M581 194 Q584 188 581 182"
      fill="none"
      stroke="#aaa"
      stroke-width="1.5"
      stroke-linecap="round"></path>
  </g>

  <!-- ── Developer sleeping (Positioned under coffee) ────── -->
  <g transform="translate(410, -60)">
    <!-- hammock -->
    <g class="hammock">
      <!-- bases -->
      <rect
        x="30"
        y="472"
        width="40"
        height="8"
        rx="4"
        fill="var(--color-border-secondary, #ccc)"></rect>
      <rect
        x="290"
        y="472"
        width="40"
        height="8"
        rx="4"
        fill="var(--color-border-secondary, #ccc)"></rect>
      <!-- poles -->
      <rect
        x="46"
        y="320"
        width="8"
        height="160"
        rx="4"
        fill="var(--color-border-secondary, #ccc)"></rect>
      <rect
        x="306"
        y="320"
        width="8"
        height="160"
        rx="4"
        fill="var(--color-border-secondary, #ccc)"></rect>
      <!-- ropes -->
      <line
        x1="54"
        y1="340"
        x2="110"
        y2="380"
        stroke="var(--color-border-secondary, #ccc)"
        stroke-width="2"></line>
      <line
        x1="54"
        y1="340"
        x2="110"
        y2="400"
        stroke="var(--color-border-secondary, #ccc)"
        stroke-width="2"></line>
      <line
        x1="306"
        y1="340"
        x2="250"
        y2="380"
        stroke="var(--color-border-secondary, #ccc)"
        stroke-width="2"></line>
      <line
        x1="306"
        y1="340"
        x2="250"
        y2="400"
        stroke="var(--color-border-secondary, #ccc)"
        stroke-width="2"></line>
      <!-- fabric -->
      <path
        d="M 110 380 C 140 480, 220 480, 250 380 C 220 500, 140 500, 110 380"
        fill="#534AB7"></path>
    </g>
    <!-- body -->
    <rect x="145" y="370" width="70" height="85" rx="12" fill="#4a5568"></rect>
    <!-- arms (behind head) -->
    <path
      d="M 150 400 L 115 375 L 160 375"
      fill="none"
      stroke="#4a5568"
      stroke-width="18"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
    <path
      d="M 210 400 L 245 375 L 200 375"
      fill="none"
      stroke="#4a5568"
      stroke-width="18"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
    <!-- head -->
    <circle cx="180" cy="390" r="28" fill="#f6d0a0"></circle>
    <!-- hair -->
    <path d="M152 378 Q162 350 180 348 Q198 350 208 378" fill="#3d2b1f"></path>
    <!-- closed eyes -->
    <path
      d="M168 388 Q172 385 176 388"
      fill="none"
      stroke="#333"
      stroke-width="1.5"
      stroke-linecap="round"></path>
    <path
      d="M184 388 Q188 385 192 388"
      fill="none"
      stroke="#333"
      stroke-width="1.5"
      stroke-linecap="round"></path>
    <!-- ZZZ -->
    <text x="212" y="370" font-family="monospace" font-size="11" fill="#999"
      >z</text
    >
    <text x="220" y="360" font-family="monospace" font-size="13" fill="#999"
      >z</text
    >
    <text x="230" y="348" font-family="monospace" font-size="15" fill="#999"
      >z</text
    >
  </g>

  <!-- ── Progress bar ─────────────────────────────────────── -->
  <rect
    x="40"
    y="295"
    width="360"
    height="72"
    rx="8"
    fill="var(--color-background-secondary, #f5f5f5)"
    stroke="var(--color-border-tertiary, #e0e0e0)"
