---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="pt-48 space-y-12">
  <div class="w-full max-w-3xl mx-auto px-4">
    <div class="bg-zinc-900/40 border border-zinc-800/60 rounded-xl overflow-hidden shadow-2xl backdrop-blur-md">
      <!-- Terminal Header -->
      <div class="bg-zinc-800/30 px-6 py-5 flex items-center gap-2 border-b border-zinc-800/50">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
          <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
          <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
        </div>
        <div class="flex-1 flex justify-center">
          <span class="text-[10px] uppercase tracking-[0.2em] text-zinc-500 font-mono font-medium">terminal — contact</span>
        </div>
        <div class="w-12"></div>
      </div>

      <!-- Terminal Body -->
      <form id="contact-form" class="p-12 font-mono text-sm md:text-base space-y-12">
        <div class="space-y-6 group/field">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-[#27c93f] font-bold">user@kernel</span>
            <span class="text-zinc-600">:</span>
            <span class="text-[#3b82f6] font-bold">~/contact</span>
            <span class="text-zinc-400">$</span>
            <label for="context" class="text-zinc-300 font-medium">{t('contact.context.label')}</label>
          </div>
          <div class="relative pl-6 border-l border-zinc-800 group-focus-within/field:border-zinc-700 transition-colors">
            <textarea
              id="context"
              name="context"
              required
              rows="3"
              placeholder={t('contact.context.placeholder')}
              class="w-full bg-transparent border-none outline-none text-zinc-100 placeholder:text-zinc-800 resize-none focus:ring-0 p-0 leading-relaxed"
            ></textarea>
          </div>
        </div>

        <div class="space-y-6 group/field">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-[#27c93f] font-bold">user@kernel</span>
            <span class="text-zinc-600">:</span>
            <span class="text-[#3b82f6] font-bold">~/contact</span>
            <span class="text-zinc-400">$</span>
            <label for="contact" class="text-zinc-300 font-medium">{t('contact.info.label')}</label>
          </div>
          <div class="relative pl-6 border-l border-zinc-800 group-focus-within/field:border-zinc-700 transition-colors flex items-center gap-4">
            <input
              id="contact"
              type="text"
              name="contact"
              required
              placeholder={t('contact.info.placeholder')}
              class="flex-1 bg-transparent border-none outline-none text-zinc-100 placeholder:text-zinc-800 focus:ring-0 p-0"
            />
            <button
              type="submit"
              class="text-zinc-500 hover:text-[#27c93f] transition-all duration-300 flex items-center gap-2 group/btn"
            >
              <span class="text-xs opacity-0 group-hover/btn:opacity-100 transition-all -translate-x-2 group-hover/btn:translate-x-0">--</span>
              <span class="font-bold uppercase tracking-widest text-[10px]">{t('contact.submit')}</span>
            </button>
          </div>
        </div>

        <div id="form-status" class="hidden opacity-0 transform translate-y-2 transition-all duration-500">
           <div class="flex items-start gap-3 text-[#27c93f]/90 bg-[#27c93f]/5 p-4 rounded-lg border border-[#27c93f]/10">
              <span class="font-bold shrink-0">✓</span>
              <span class="leading-relaxed">{t('contact.success')}</span>
           </div>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  import { actions } from 'astro:actions';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status');
  
  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const contextData = formData.get('context')?.toString() || "";
      const contactData = formData.get('contact')?.toString() || "";

      const btn = form.querySelector('button[type="submit"]');
      if (btn) btn.setAttribute('disabled', 'true');
      
      try {
        const { data, error } = await actions.sendContact({
          context: contextData,
          contact: contactData,
        });

        if (!error && data) {
          status.classList.remove('hidden');
          requestAnimationFrame(() => {
            status.classList.add('opacity-100', 'translate-y-0');
          });
          form.reset();
        } else {
          console.error('Error al enviar mensaje:', error);
          alert('Hubo un error al enviar el mensaje. Por favor intenta de nuevo.');
        }
      } catch (error) {
        console.error('Error de red:', error);
      } finally {
        if (btn) btn.removeAttribute('disabled');
      }
    });
  }
</script>

<style>
  textarea, input {
    caret-color: #27c93f;
  }
  
  textarea::placeholder, input::placeholder {
    font-style: italic;
  }

  textarea::-webkit-scrollbar {
    width: 4px;
  }
  textarea::-webkit-scrollbar-track {
    background: transparent;
  }
  textarea::-webkit-scrollbar-thumb {
    background: #27272a;
    border-radius: 10px;
  }
</style>
