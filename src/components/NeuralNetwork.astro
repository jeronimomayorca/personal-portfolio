---
/**
 * NeuralNetwork.astro
 * ------------------
 * A minimalist, animated neural-network / node-diagram rendered on <canvas>.
 * Lines are 1px with a very soft glow; GSAP drives an almost-imperceptible
 * data-pulse that flows along the edges to suggest AI & connectivity.
 */
---

<canvas id="neural-network-canvas" class="neural-net-canvas"></canvas>

<style>
  .neural-net-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
    pointer-events: none;
    opacity: 0;                      /* faded in via GSAP */
  }
</style>

<script>
  import { gsap } from "gsap";

  /* ── Types ─────────────────────────────────────────────────── */
  interface NNode {
    x: number;
    y: number;
    vx: number;
    vy: number;
    radius: number;
    baseAlpha: number;
  }

  interface Edge {
    a: number;
    b: number;
    pulseOffset: number;           /* 0 → 1 random start */
    pulseSpeed: number;            /* seconds per full cycle */
    pulseDir: number;              /* 1 or -1 */
  }

  /* ── Config ────────────────────────────────────────────────── */
  const NODE_COUNT           = 40;
  const CONNECTION_RADIUS    = 240;   // px — max distance to draw an edge
  const MAX_EDGES_PER_NODE   = 4;
  const NODE_DRIFT_SPEED     = 0.1;   // px / frame
  const GLOW_COLOR           = "rgba(255, 255, 255,";  // base; alpha appended
  const NODE_DOT_RADIUS_MIN  = 1.4;
  const NODE_DOT_RADIUS_MAX  = 2.6;

  /* ── State ─────────────────────────────────────────────────── */
  let canvas: HTMLCanvasElement | null = null;
  let ctx: CanvasRenderingContext2D | null = null;
  let nodes: NNode[] = [];
  let edges: Edge[] = [];
  let W = 0;
  let H = 0;
  let rafId = 0;
  let globalPulse = { t: 0 };    // driven by GSAP
  let fadeAlpha = { value: 0 };  // overall opacity controlled by GSAP

  /* ── Helpers ───────────────────────────────────────────────── */
  function rand(min: number, max: number) {
    return Math.random() * (max - min) + min;
  }

  function resize() {
    if (!canvas) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    W = canvas.clientWidth;
    H = canvas.clientHeight;
    canvas.width  = W * dpr;
    canvas.height = H * dpr;
    ctx?.scale(dpr, dpr);
  }

  /* ── Init geometry ─────────────────────────────────────────── */
  function createNodes() {
    nodes = [];
    // Create nodes in a padded area with a slight center-bias
    for (let i = 0; i < NODE_COUNT; i++) {
      // Gaussian-ish distribution towards center
      const cx = W / 2;
      const cy = H / 2;
      const spreadX = W * 0.42;
      const spreadY = H * 0.42;
      const angle = Math.random() * Math.PI * 2;
      const dist = Math.pow(Math.random(), 0.6); // bias slightly outward for spread
      const x = cx + Math.cos(angle) * dist * spreadX;
      const y = cy + Math.sin(angle) * dist * spreadY;

      nodes.push({
        x,
        y,
        vx: rand(-NODE_DRIFT_SPEED, NODE_DRIFT_SPEED),
        vy: rand(-NODE_DRIFT_SPEED, NODE_DRIFT_SPEED),
        radius: rand(NODE_DOT_RADIUS_MIN, NODE_DOT_RADIUS_MAX),
        baseAlpha: rand(0.3, 0.7),
      });
    }
  }

  function createEdges() {
    edges = [];
    const edgeCount: number[] = new Array(NODE_COUNT).fill(0);

    for (let i = 0; i < NODE_COUNT; i++) {
      for (let j = i + 1; j < NODE_COUNT; j++) {
        if (edgeCount[i] >= MAX_EDGES_PER_NODE || edgeCount[j] >= MAX_EDGES_PER_NODE) continue;
        const dx = nodes[i].x - nodes[j].x;
        const dy = nodes[i].y - nodes[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONNECTION_RADIUS) {
          edges.push({
            a: i,
            b: j,
            pulseOffset: Math.random(),
            pulseSpeed: rand(3, 7),
            pulseDir: Math.random() > 0.5 ? 1 : -1,
          });
          edgeCount[i]++;
          edgeCount[j]++;
        }
      }
    }
  }

  /* ── Drawing ───────────────────────────────────────────────── */
  function draw() {
    if (!ctx) return;
    ctx.clearRect(0, 0, W, H);

    const alpha = fadeAlpha.value;
    if (alpha <= 0.001) return;

    // ── Drift nodes ───
    for (const n of nodes) {
      n.x += n.vx;
      n.y += n.vy;
      // Soft bounce off edges with margin
      const m = 40;
      if (n.x < -m || n.x > W + m) n.vx *= -1;
      if (n.y < -m || n.y > H + m) n.vy *= -1;
    }

    const t = globalPulse.t;  // 0-1 looping pulse from GSAP

    // ── Draw edges ────
    for (const e of edges) {
      const a = nodes[e.a];
      const b = nodes[e.b];
      const dx = b.x - a.x;
      const dy = b.y - a.y;
      const dist = Math.sqrt(dx * dx + dy * dy);

      // Fade edges that are getting far apart
      const distFade = Math.max(0, 1 - dist / (CONNECTION_RADIUS * 1.2));

      // Base line — very faint
      const baseA = 0.1 * distFade * alpha;
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = `${GLOW_COLOR}${baseA})`;
      ctx.lineWidth = 1;
      ctx.stroke();

      // ── Pulse (data-flow) ──
      // A small bright dot that travels along the edge
      const raw = (t / e.pulseSpeed + e.pulseOffset) % 1;
      const pos = e.pulseDir === 1 ? raw : 1 - raw;
      const px = a.x + dx * pos;
      const py = a.y + dy * pos;

      // Glow dot
      const pulseAlpha = 0.4 * distFade * alpha;
      const grad = ctx.createRadialGradient(px, py, 0, px, py, 16);
      grad.addColorStop(0, `${GLOW_COLOR}${pulseAlpha})`);
      grad.addColorStop(1, `${GLOW_COLOR}0)`);
      ctx.beginPath();
      ctx.arc(px, py, 16, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();

      // Bright core of pulse
      ctx.beginPath();
      ctx.arc(px, py, 2, 0, Math.PI * 2);
      ctx.fillStyle = `${GLOW_COLOR}${Math.min(pulseAlpha * 2, 1)})`;
      ctx.fill();
    }

    // ── Draw nodes ────
    for (const n of nodes) {
      const a = n.baseAlpha * alpha;
      // Outer glow
      const grad = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.radius * 5);
      grad.addColorStop(0, `${GLOW_COLOR}${a * 0.6})`);
      grad.addColorStop(1, `${GLOW_COLOR}0)`);
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.radius * 5, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();

      // Core
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.radius, 0, Math.PI * 2);
      ctx.fillStyle = `${GLOW_COLOR}${a})`;
      ctx.fill();
    }
  }

  /* ── Animation loop ────────────────────────────────────────── */
  function tick() {
    draw();
    rafId = requestAnimationFrame(tick);
  }

  /* ── Bootstrap ─────────────────────────────────────────────── */
  function initNeuralNetwork() {
    canvas = document.querySelector<HTMLCanvasElement>("#neural-network-canvas");
    if (!canvas) return;
    ctx = canvas.getContext("2d");
    if (!ctx) return;

    resize();
    createNodes();
    createEdges();

    // Continuous GSAP tween that drives the pulse `t` from 0 → a large number
    // We use modular arithmetic inside draw() per edge
    gsap.killTweensOf(globalPulse);
    gsap.killTweensOf(fadeAlpha);
    globalPulse.t = 0;
    fadeAlpha.value = 0;

    gsap.to(globalPulse, {
      t: 1000,           // just keep counting
      duration: 1000,    // 1 second = 1 unit
      ease: "none",
      repeat: -1,
    });

    // Fade the canvas in softly
    gsap.to(fadeAlpha, {
      value: 1,
      duration: 2.5,
      ease: "power2.out",
    });

    // Also set the CSS opacity so the canvas element itself is visible
    gsap.to(canvas, {
      opacity: 1,
      duration: 2.5,
      ease: "power2.out",
    });

    // Start render loop
    cancelAnimationFrame(rafId);
    tick();

    // Handle resize
    const onResize = () => {
      resize();
      createNodes();
      createEdges();
    };
    window.addEventListener("resize", onResize);
  }

  function cleanupNeuralNetwork() {
    cancelAnimationFrame(rafId);
    gsap.killTweensOf(globalPulse);
    gsap.killTweensOf(fadeAlpha);
  }

  /* ── Lifecycle ─────────────────────────────────────────────── */
  document.addEventListener("astro:page-load", () => {
    cleanupNeuralNetwork();
    initNeuralNetwork();
  });

  document.addEventListener("astro:before-preparation", cleanupNeuralNetwork);

  if (document.readyState === "complete") {
    initNeuralNetwork();
  } else {
    document.addEventListener("DOMContentLoaded", initNeuralNetwork);
  }
</script>
