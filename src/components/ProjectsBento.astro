---
import { ArrowUpRight } from 'lucide-react';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = [
  {
    id: 'vigia',
    title: t('projects.vigia.title'),
    desc: t('projects.vigia.desc'),
    image: '/vigia.webp',
    tags: ['Python', 'OpenCV', 'TensorFlow', 'FastAPI'],
    accent: '#8b5cf6',
    accentName: 'violet',
    size: 'large',
    live: '#',
  },
  {
    id: 'lexai',
    title: t('projects.lexai.title'),
    desc: t('projects.lexai.desc'),
    image: '/lexai.png',
    tags: ['Python', 'FastAPI', 'React', 'Gemini API'],
    accent: '#3b82f6',
    accentName: 'blue',
    size: 'small',
    live: '#',
  },
  {
    id: 'sahara',
    title: t('projects.sahara.title'),
    desc: t('projects.sahara.desc'),
    image: '/sahara.png',
    tags: ['Next.js', 'Stripe', 'Sanity CMS', 'Tailwind'],
    accent: '#f59e0b',
    accentName: 'amber',
    size: 'small',
    live: 'https://saharaessence.vercel.app',
  },
  {
    id: 'velosecure',
    title: t('projects.velosecure.title'),
    desc: t('projects.velosecure.desc'),
    image: '/velosecure.webp',
    tags: ['React Native', 'Node.js', 'MQTT', 'PostgreSQL'],
    accent: '#10b981',
    accentName: 'emerald',
    size: 'large',
    live: '#',
  },
];
---

<div class="bento-grid">
  {projects.map((project, index) => (
    <article
      class={`bento-card bento-${project.size} bento-accent-${project.accentName}`}
      style={`--accent: ${project.accent}; --delay: ${index * 0.1}s`}
      id={`project-${project.id}`}
    >
      <!-- Image -->
      <div class="bento-image-wrapper">
        <img
          src={project.image}
          alt={project.title}
          class="bento-image"
          loading="lazy"
        />
        <div class="bento-image-overlay"></div>
      </div>

      <!-- Content -->
      <div class="bento-content">
        <div class="bento-header">
          <h3 class="bento-title">{project.title}</h3>
          <div class="bento-links">
            {project.live && (
              <a href={project.live} target={project.live === '#' ? '_self' : '_blank'} rel="noopener noreferrer" class="bento-link" aria-label={`${project.title} Live`}>
                <ArrowUpRight size={16} />
              </a>
            )}
          </div>
        </div>

        <p class="bento-desc">{project.desc}</p>

        <div class="bento-tags">
          {project.tags.map((tag) => (
            <span class="bento-tag">{tag}</span>
          ))}
        </div>
      </div>

      <!-- Accent glow -->
      <div class="bento-glow"></div>
    </article>
  ))}
</div>

<style>
  /* ╔══════════════════════════════════════════════╗
     ║            BENTO GRID LAYOUT                ║
     ╚══════════════════════════════════════════════╝ */

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1rem;
    width: 100%;
  }

  /* Large cards span 7 cols, small cards span 5 cols */
  .bento-large:nth-child(1) { grid-column: span 7; }
  .bento-small:nth-child(2) { grid-column: span 5; }
  .bento-small:nth-child(3) { grid-column: span 5; }
  .bento-large:nth-child(4) { grid-column: span 7; }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
    .bento-large,
    .bento-small {
      grid-column: span 1 !important;
    }
  }

  /* ╔══════════════════════════════════════════════╗
     ║              CARD BASE                      ║
     ╚══════════════════════════════════════════════╝ */

  .bento-card {
    position: relative;
    border-radius: 1.25rem;
    border: 1px solid var(--color-border);
    background: #111113;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 420px;
    transition: border-color 0.4s ease, transform 0.4s ease, box-shadow 0.4s ease;
    animation: bentoFadeIn 0.6s ease-out both;
    animation-delay: var(--delay);
  }

  .bento-card:hover {
    border-color: color-mix(in srgb, var(--accent) 50%, transparent);
    transform: translateY(-4px);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--accent) 15%, transparent),
      0 20px 40px -12px color-mix(in srgb, var(--accent) 15%, transparent);
  }

  /* ╔══════════════════════════════════════════════╗
     ║              IMAGE SECTION                  ║
     ╚══════════════════════════════════════════════╝ */

  .bento-image-wrapper {
    position: relative;
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .bento-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease, filter 0.4s ease;
    filter: brightness(0.85) saturate(0.9);
  }

  .bento-card:hover .bento-image {
    transform: scale(1.05);
    filter: brightness(1) saturate(1);
  }

  .bento-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 40%,
      #111113 100%
    );
    pointer-events: none;
  }

  /* ╔══════════════════════════════════════════════╗
     ║              CONTENT SECTION                ║
     ╚══════════════════════════════════════════════╝ */

  .bento-content {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
    position: relative;
    z-index: 2;
    margin-top: -2rem;
  }

  .bento-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .bento-title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--color-foreground);
  }

  .bento-links {
    display: flex;
    gap: 0.5rem;
  }

  .bento-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    transition: all 0.3s ease;
    background: transparent;
  }

  .bento-link:hover {
    color: var(--color-foreground);
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .bento-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bento-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
    padding-top: 0.25rem;
  }

  .bento-tag {
    font-size: 0.6875rem;
    font-family: var(--font-family-mono);
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    letter-spacing: 0.01em;
    transition: all 0.3s ease;
  }

  .bento-card:hover .bento-tag {
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
  }

  /* ╔══════════════════════════════════════════════╗
     ║              ACCENT GLOW                    ║
     ╚══════════════════════════════════════════════╝ */

  .bento-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
      circle at center,
      color-mix(in srgb, var(--accent) 6%, transparent),
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 0;
  }

  .bento-card:hover .bento-glow {
    opacity: 1;
  }

  /* ╔══════════════════════════════════════════════╗
     ║              ANIMATION                      ║
     ╚══════════════════════════════════════════════╝ */

  @keyframes bentoFadeIn {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
