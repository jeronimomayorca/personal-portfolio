---
import Layout from '../layouts/Layout.astro';
import ProjectsBento from '../components/ProjectsBento.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('projects.title')}>
	<section class="projects-page animate-fade-in">
		<div class="projects-header">
			<h1 class="text-4xl md:text-5xl font-extrabold tracking-tighter leading-tight">
				{t('projects.title')}
			</h1>
			<p class="text-lg text-muted max-w-xl leading-relaxed">
				{t('projects.subtitle')}
			</p>
		</div>

		<ProjectsBento />
	</section>
</Layout>

<style>
	.projects-page {
		padding-bottom: 4rem;
	}
	.projects-header {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 2.5rem;
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.animate-fade-in {
		animation: fadeIn 0.8s ease-out forwards;
	}
</style>
