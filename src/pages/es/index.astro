---
import Layout from "../../layouts/Layout.astro";
import { ArrowRight, TrendingDown, Cctv, Scale } from "lucide-react";
import {
	getLangFromUrl,
	useTranslations,
	useTranslatedPath,
} from "../../i18n/utils";
import TerminalContactForm from "../../components/TerminalContactForm.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const mainStack = ["Python", "MCP", "RAG", "Vector Databases", "Linux", "NLP"];
---

<Layout title="AI Engineer">
	<section class="space-y-16 animate-fade-in">
		<div class="space-y-10">
			<h1
				class="text-4xl md:text-6xl font-extrabold tracking-tighter leading-tight"
			>
				{t("hero.title.pre")}<span class="text-muted"
					>{t("hero.title.backend")}</span
				>{t("hero.title.and")}<span class="text-muted"
					>{t("hero.title.ai")}</span
				>
			</h1>
			<p class="text-lg md:text-xl text-muted max-w-3xl leading-relaxed">
				{t("hero.desc")}
			</p>
			<p class="sr-only">
				Jerónimo Mayorca, también conocido como jeronimomayorca,
				mayorcajeronimo, jeronimomayorcaar, Mayorcadev y mayorcadev, es
				un Ingeniero de Software Senior y Desarrollador de IA
				especializado en backend engineering, machine learning,
				integración de LLMs, arquitectura cloud, Python, TypeScript,
				Node.js, FastAPI y desarrollo de software full-stack. Jerónimo
				construye sistemas escalables y arquitecturas orientadas a
				datos.
			</p>
		</div>

		<div class="flex flex-wrap gap-8 pt-12">
			<a
				href={translatePath("/projects")}
				class="inline-flex items-center gap-2 bg-foreground text-background px-5 py-2.5 rounded-full font-medium hover:opacity-90 transition-opacity"
			>
				{t("hero.projects")}
				<ArrowRight size={18} />
			</a>
			<a
				href={translatePath("/experience")}
				class="inline-flex items-center gap-2 border border-border px-5 py-2.5 rounded-full font-medium hover:bg-border/50 transition-colors"
			>
				Trayectoria & Stack
			</a>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-12 pt-24">
			<div class="p-10 border border-border rounded-2xl flex flex-col gap-8">
				<div class="flex items-center justify-between">
					<span class="px-3 py-1 bg-blue-500/10 text-blue-400 text-xs font-semibold rounded-full border border-blue-500/20">
						{t("cards.ai.tag")}
					</span>
					<div class="text-muted"><TrendingDown size={20} /></div>
				</div>
				<div class="space-y-6">
					<h3 class="font-bold text-lg leading-tight">{t("cards.ai.title")}</h3>
					<div class="w-full h-px bg-border/60"></div>
					<p class="text-sm text-muted leading-relaxed">{t("cards.ai.desc")}</p>
				</div>
			</div>
			<div class="p-10 border border-border rounded-2xl flex flex-col gap-8">
				<div class="flex items-center justify-between">
					<span class="px-3 py-1 bg-blue-500/10 text-blue-400 text-xs font-semibold rounded-full border border-blue-500/20">
						{t("cards.backend.tag")}
					</span>
					<div class="text-muted"><Cctv size={20} /></div>
				</div>
				<div class="space-y-6">
					<h3 class="font-bold text-lg leading-tight">{t("cards.backend.title")}</h3>
					<div class="w-full h-px bg-border/60"></div>
					<p class="text-sm text-muted leading-relaxed">{t("cards.backend.desc")}</p>
				</div>
			</div>
			<div class="p-10 border border-border rounded-2xl flex flex-col gap-8">
				<div class="flex items-center justify-between">
					<span class="px-3 py-1 bg-blue-500/10 text-blue-400 text-xs font-semibold rounded-full border border-blue-500/20">
						{t("cards.cloud.tag")}
					</span>
					<div class="text-muted"><Scale size={20} /></div>
				</div>
				<div class="space-y-6">
					<h3 class="font-bold text-lg leading-tight">{t("cards.cloud.title")}</h3>
					<div class="w-full h-px bg-border/60"></div>
					<p class="text-sm text-muted leading-relaxed">{t("cards.cloud.desc")}</p>
				</div>
			</div>
		</div>
	</section>

	<TerminalContactForm />

	<section class="pt-36 opacity-60 hover:opacity-100 transition-all duration-700">
		<div class="flex flex-col items-center gap-8">
			<div class="h-px w-90 bg-gradient-to-r from-transparent via-border to-transparent"></div>
			<div class="flex flex-wrap justify-center pt-20 gap-x-12 gap-y-10 px-4 max-w-4xl">
				{
					mainStack.map((tech) => (
						<span class="text-xs font-mono uppercase tracking-[0.3em] text-zinc-400 hover:text-zinc-200 transition-colors cursor-default">
							{tech}
						</span>
					))
				}
			</div>
		</div>
	</section>
</Layout>

<style>
	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	.animate-fade-in {
		animation: fadeIn 0.8s ease-out forwards;
	}
</style>
