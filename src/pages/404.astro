---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout
  title="404 | Jeronimo Mayorca"
  description="Página no encontrada o en construcción."
>
  <div class="fixed inset-0 w-full h-full z-50 bg-background">
    <!-- La imagen ahora es la protagonista absoluta sin filtros oscuros -->
    <img
      src="/elazote.png"
      alt="Página no encontrada"
      class="w-full h-full object-cover object-center"
    />

    <!-- Controles y textos en el centro de la parte inferior -->
    <div
      class="absolute bottom-10 left-1/2 -translate-x-1/2 md:bottom-16 w-full px-4 flex flex-col items-center gap-3 z-10 text-center"
    >
      <!-- Bloque/Espacio reservado para que edites tu texto -->
      <div
        class="max-w-sm mb-2 rounded-lg bg-background/40 backdrop-blur-sm p-4 border border-border/50"
      >
        <p class="text-foreground font-medium text-lg drop-shadow-md">
          Estamos azotando lo mas fuerte posible los servidores de Google y
          Anthropic para acabar la pagina que buscabas lo mas pronto posible.
          Disculpa las molestias :)
        </p>
      </div>
    </div>

    <div
      class="absolute bottom-10 left-1/2 -translate-x-1/2 md:bottom-16 w-full px-4 flex flex-col items-end gap-3 z-10 text-center"
    >
      <!-- Botón de regresar -->
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-orange-500 to-red-600 text-white font-bold rounded-lg hover:from-orange-600 hover:to-red-700 hover:scale-105 transition-all duration-300 shadow-[0_0_15px_rgba(239,68,68,0.5)] hover:shadow-[0_0_25px_rgba(239,68,68,0.7)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        Volver al inicio
      </a>
    </div>
  </div>
</Layout>
