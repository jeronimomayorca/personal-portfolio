---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const milestonesData = {
  en: [
    {
      date: "Mar 2026 — Present",
      role: "Founder & Product Engineer",
      company: "Lex AI",
      url: "#",
      description: "Legal platform with AI Interviewer automating client intake ensuring 100% completeness. RAG pipeline on ChromaDB with semantic search against precedents and statutes. 85% reduction in manual data collection.",
      skills: ["Python", "ChromaDB", "RAG", "LLM"]
    },
    {
      date: "Feb 2026 — Present",
      role: "Founder & AI Developer",
      company: "VigIA",
      url: "#",
      description: "Surveillance system with YOLOv8 classifying real threats vs. environmental noise in IP camera streams. Zone-based detection with automated API alerts and minimal latency.",
      skills: ["YOLOv8", "Computer Vision", "Python", "Deep Learning"]
    },
    {
      date: "Aug 2025 — Feb 2026 · 7 mos",
      role: "Marketing Executive",
      company: "EVOLVE your English",
      url: "https://evolveyourenglish.com/",
      description: "Client acquisition and market positioning. Translation of technical specs into value propositions, skills directly applied to the GTM of VigIA and Lex AI.",
      skills: ["Marketing", "Negotiation", "GTM"]
    },
    {
      date: "Jul 2025 — Sep 2025 · 3 mos",
      role: "Fullstack Developer",
      company: "Sahara Essence",
      url: "https://saharaessence.vercel.app",
      description: "Luxury e-commerce with AI Fragrance Advisor: LLM chatbot + RAG on real-time Supabase inventory. Premium UI/UX with sub-second responses.",
      skills: ["RAG", "Supabase", "LLM", "E-commerce"]
    },
    {
      date: "Sep 2024 — Sep 2025 · 1 yr",
      role: "Senior Teacher",
      company: "Colegiatura del Café",
      description: "Teaching algorithms, basic programming, hardware-software integration, and advanced Excel. Simplification of architecture concepts for higher education students.",
      skills: ["Algorithms", "Hardware", "Excel"]
    },
    {
      date: "Jan 2025 — Feb 2025 · 2 mos",
      role: "Back End Developer",
      company: "Xarasoft S.A.S",
      description: "Backend for school ERP: dynamic academic weighting algorithms and AJAX interfaces with real-time data consistency.",
      skills: ["PHP", "MySQL", "AJAX", "Bootstrap"]
    },
    {
      date: "Jun 2023 — Mar 2024 · 10 mos",
      role: "Fullstack Developer",
      company: "Humphrey Consulting Group",
      url: "https://humphreysoft.com/",
      description: "ZOHO integration with 25% lower latency, DIAN compliance module using Frappe, and cloud audit reducing costs by 40%. Refactored 30+ critical Python endpoints.",
      skills: ["Python", "Docker", "SQL", "Frappe", "ZOHO"]
    }
  ],
  es: [
    {
      date: "Mar 2026 — Presente",
      role: "Founder & Product Engineer",
      company: "Lex AI",
      url: "#",
      description: "Plataforma legal con AI Interviewer que automatiza el intake de clientes garantizando 100% de completitud. Pipeline RAG sobre ChromaDB con búsqueda semántica contra precedentes y estatutos. Reducción del 85% en recolección manual de datos.",
      skills: ["Python", "ChromaDB", "RAG", "LLM"]
    },
    {
      date: "Feb 2026 — Presente",
      role: "Founder & AI Developer",
      company: "VigIA",
      url: "#",
      description: "Sistema de vigilancia con YOLOv8 que clasifica amenazas reales vs. ruido ambiental en streams de cámaras IP. Detección por zonas con alertas automatizadas vía API y latencia mínima.",
      skills: ["YOLOv8", "Computer Vision", "Python", "Deep Learning"]
    },
    {
      date: "Ago 2025 — Feb 2026 · 7 meses",
      role: "Ejecutivo de Marketing",
      company: "EVOLVE your English",
      url: "https://evolveyourenglish.com/",
      description: "Adquisición de clientes y posicionamiento de mercado. Traducción de specs técnicas en propuestas de valor, habilidades aplicadas directamente al GTM de VigIA y Lex AI.",
      skills: ["Marketing", "Negociación", "GTM"]
    },
    {
      date: "Jul 2025 — Sep 2025 · 3 meses",
      role: "Fullstack Developer",
      company: "Sahara Essence",
      url: "https://saharaessence.vercel.app",
      description: "E-commerce de lujo con AI Fragrance Advisor: chatbot LLM + RAG sobre inventario Supabase en tiempo real. UI/UX premium con respuestas sub-segundo.",
      skills: ["RAG", "Supabase", "LLM", "E-commerce"]
    },
    {
      date: "Sep 2024 — Sep 2025 · 1 año",
      role: "Profesor Superior",
      company: "Colegiatura del Café",
      description: "Docencia en algoritmos, programación básica, hardware-software integration y Excel avanzado. Simplificación de conceptos de arquitectura para estudiantes de nivel superior.",
      skills: ["Algoritmos", "Hardware", "Excel"]
    },
    {
      date: "Ene 2025 — Feb 2025 · 2 meses",
      role: "Back End Developer",
      company: "Xarasoft S.A.S",
      description: "Backend para ERP escolar: algoritmos de ponderación académica dinámica e interfaces AJAX con consistencia de datos en tiempo real.",
      skills: ["PHP", "MySQL", "AJAX", "Bootstrap"]
    },
    {
      date: "Jun 2023 — Mar 2024 · 10 meses",
      role: "Fullstack Developer",
      company: "Humphrey Consulting Group",
      url: "https://humphreysoft.com/",
      description: "Integración ZOHO con 25% menos latencia, módulo de cumplimiento DIAN con Frappe y auditoría cloud que redujo costos un 40%. Refactoring de 30+ endpoints críticos en Python.",
      skills: ["Python", "Docker", "SQL", "Frappe", "ZOHO"]
    }
  ]
};

const milestones = lang === 'es' ? milestonesData.es : milestonesData.en;
const pageTitle = lang === 'es' ? 'Recorrido Profesional' : 'Experience Journey';
---

<Layout title={pageTitle} fullWidth={true}>
  <div id="drone-container" class="w-full relative h-screen overflow-hidden bg-background [perspective:1500px]">
    
    <div id="camera-wrapper" class="w-full h-full absolute top-0 left-0 origin-center [transform-style:preserve-3d]">
      
      <!-- Tech Grid Background -->
      <div class="tech-grid absolute inset-[-50%] w-[200%] h-[200%] opacity-30 z-0 pointer-events-none"></div>

      <!-- Geometric Pattern Layer: Hexagons -->
      <div id="geo-pattern" class="absolute inset-[-50%] w-[200%] h-[200%] z-0 pointer-events-none opacity-[0.30]">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="hexagons" x="0" y="0" width="120" height="104" patternUnits="userSpaceOnUse">
              <polygon points="60,2 110,28 110,76 60,102 10,76 10,28" fill="none" stroke="white" stroke-width="0.6" />
              <polygon points="120,54 170,80 170,128 120,154 70,128 70,80" fill="none" stroke="white" stroke-width="0.4" opacity="0.6" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#hexagons)" />
        </svg>
      </div>

      <!-- Geometric Pattern Layer: Diamond Lattice -->
      <div id="geo-pattern-2" class="absolute inset-[-60%] w-[220%] h-[220%] z-0 pointer-events-none opacity-[0.24]">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="diamonds" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
              <polygon points="40,0 80,40 40,80 0,40" fill="none" stroke="white" stroke-width="0.5" />
              <line x1="40" y1="0" x2="40" y2="80" stroke="white" stroke-width="0.2" opacity="0.4" />
              <line x1="0" y1="40" x2="80" y2="40" stroke="white" stroke-width="0.2" opacity="0.4" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#diamonds)" />
        </svg>
      </div>

      <!-- Geometric Pattern Layer: Diagonal Lines -->
      <div id="geo-pattern-3" class="absolute inset-[-40%] w-[180%] h-[180%] z-0 pointer-events-none opacity-[0.36]">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="diagonals" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
              <line x1="0" y1="40" x2="40" y2="0" stroke="white" stroke-width="0.4" opacity="0.5" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#diagonals)" />
        </svg>
      </div>

      <div id="map-layer" class="w-full absolute top-0 left-0 z-10">
        
        <!-- Physical cable on the ground -->
        <div class="absolute left-8 md:left-1/2 top-[50vh] w-1 bg-white/10 md:-translate-x-1/2 z-0 rounded-full" style={`height: ${(milestones.length - 1) * 100}vh;`}></div>
        <!-- Active light beam -->
        <div id="active-cable" class="absolute left-8 md:left-1/2 top-[50vh] w-1 bg-foreground shadow-[0_0_20px_2px_rgba(255,255,255,0.6)] md:-translate-x-1/2 z-10 rounded-full" style="height: 0px;"></div>

        {milestones.map((m, i) => (
          <div class="w-full h-screen flex items-center justify-center relative">
            
            <!-- Connection point -->
            <div class="absolute left-8 md:left-1/2 top-1/2 w-6 h-6 bg-background border-[3px] border-border/50 rounded-full -translate-x-1/2 -translate-y-1/2 z-20 node-dot transition-colors duration-300 flex items-center justify-center">
              <div class="w-2.5 h-2.5 bg-foreground rounded-full opacity-0 scale-0 dot-inner shadow-[0_0_10px_rgba(255,255,255,0.8)]"></div>
            </div>

            <!-- Horizontal Line connector (Desktop only) -->
            <div class={`hidden md:block absolute top-1/2 h-[2px] bg-gradient-to-r ${i % 2 === 0 ? 'from-border/50 to-transparent left-1/2 w-24' : 'from-transparent to-border/50 right-1/2 w-24'} -translate-y-1/2 z-0`}></div>

            <div class={`w-full max-w-6xl mx-auto flex items-center h-full ${i % 2 === 0 ? 'justify-end pl-20 pr-6 md:pl-0 md:pr-24' : 'justify-start pl-20 pr-6 md:pl-24'}`}>
              
              <!-- Card -->
              <div class="node w-full md:w-[48%] relative z-30 [perspective:1000px]">
                <div class="node-card opacity-0 bg-background/80 border border-border backdrop-blur-2xl p-8 md:p-10 rounded-3xl shadow-2xl [transform-style:preserve-3d] overflow-hidden group hover:border-foreground/30 transition-colors duration-500">
                  
                  <!-- Decorative scanning effect -->
                  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-foreground/5 to-transparent h-[200%] -translate-y-[150%] group-hover:animate-scan pointer-events-none"></div>
                  
                  <!-- Header: Date -->
                  <div class="flex flex-wrap justify-between items-center gap-4 mb-6">
                    <span class="node-date text-foreground font-mono text-sm tracking-widest uppercase font-semibold">{m.date}</span>
                  </div>
                  
                  <!-- Title & Role -->
                  <div class="mb-6">
                    <h2 class="node-title text-3xl md:text-4xl font-extrabold tracking-tight text-foreground mb-3">{m.role}</h2>
                    <h3 class="node-company text-lg md:text-xl text-muted font-medium flex items-center gap-3">
                      <span class="w-6 h-[1px] bg-muted/50"></span> 
                      {m.url ? (
                        <a 
                          href={m.url} 
                          target={m.url === '#' ? '_self' : '_blank'} 
                          rel="noopener noreferrer" 
                          class="group/link flex items-center gap-1 hover:text-foreground transition-colors overflow-hidden"
                        >
                          {m.company}
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 -translate-x-2 translate-y-1 group-hover/link:opacity-100 group-hover/link:translate-x-0 group-hover/link:-translate-y-0.5 transition-all duration-300">
                            <line x1="7" y1="17" x2="17" y2="7"></line>
                            <polyline points="7 7 17 7 17 17"></polyline>
                          </svg>
                        </a>
                      ) : (
                        <span>{m.company}</span>
                      )}
                    </h3>
                  </div>
                  
                  <!-- Description -->
                  <p class="node-desc text-base md:text-lg text-muted/90 leading-relaxed mb-8">
                    {m.description}
                  </p>
                  
                  <!-- Skills -->
                  <div class="node-skills flex flex-wrap gap-2">
                    {m.skills.map(skill => (
                      <span class="px-3 py-1.5 border border-border/50 bg-background/50 rounded-lg text-xs font-mono text-muted/80">{skill}</span>
                    ))}
                  </div>

                </div>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Scroll Hint -->
    <div id="scroll-hint" class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center z-40">
      <span class="text-sm md:text-base text-foreground tracking-[0.3em] uppercase font-extrabold mb-2">Scroll</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce text-foreground mt-2">
        <path d="M12 5v14"/>
        <path d="m19 12-7 7-7-7"/>
      </svg>
    </div>
  </div>
</Layout>

<style>
  .tech-grid {
    background-size: 60px 60px;
    background-image: 
      linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent);
  }

  #geo-pattern,
  #geo-pattern-2,
  #geo-pattern-3 {
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 70%);
  }
  
  @keyframes scan {
    0% { transform: translateY(-150%); }
    100% { transform: translateY(50%); }
  }
  
  .animate-scan {
    animation: scan 3s linear infinite;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initExperience = () => {
    const droneContainer = document.querySelector("#drone-container");
    const cameraWrapper = document.querySelector("#camera-wrapper");
    const mapLayer = document.querySelector("#map-layer");
    const nodes = gsap.utils.toArray<HTMLElement>(".node");
    const dots = gsap.utils.toArray<HTMLElement>(".node-dot");
    const dotsInner = gsap.utils.toArray<HTMLElement>(".dot-inner");
    const activeCable = document.querySelector("#active-cable");
    const scrollHint = document.querySelector("#scroll-hint");
    const geoPattern1 = document.querySelector("#geo-pattern");
    const geoPattern2 = document.querySelector("#geo-pattern-2");
    const geoPattern3 = document.querySelector("#geo-pattern-3");

    if (!droneContainer || nodes.length === 0) return;

    ScrollTrigger.getAll().forEach(t => t.kill());

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: droneContainer,
        start: "top top",
        end: `+=${nodes.length * 150}%`,
        pin: true,
        scrub: 1.5,
      }
    });

    // --- Intro Sequence ---
    tl.addLabel("intro");
    
    tl.fromTo(cameraWrapper, 
      { rotationX: 45, scale: 0.7, opacity: 0, y: 100 },
      { rotationX: 10, scale: 0.95, opacity: 1, y: 0, duration: 2, ease: "power2.out" }, 
      "intro"
    );

    // Animate geometric patterns with parallax
    if (geoPattern1) {
      tl.fromTo(geoPattern1, 
        { rotation: 0, scale: 1 },
        { rotation: 8, scale: 1.05, duration: 2, ease: "none" },
        "intro"
      );
    }
    if (geoPattern2) {
      tl.fromTo(geoPattern2, 
        { rotation: 0, scale: 1 },
        { rotation: -5, scale: 1.03, duration: 2, ease: "none" },
        "intro"
      );
    }
    if (geoPattern3) {
      tl.fromTo(geoPattern3, 
        { rotation: 0 },
        { rotation: 3, duration: 2, ease: "none" },
        "intro"
      );
    }
    
    tl.to(scrollHint, { opacity: 0, duration: 1 }, "intro+=1");

    const node0Card = nodes[0].querySelector('.node-card');
    const node0Elems = nodes[0].querySelectorAll('.node-date, .node-metric, .node-title, .node-company, .node-desc, .node-skills span');
    
    tl.to(dots[0], { borderColor: "#ededed", duration: 0.5 }, "intro+=1");
    tl.to(dotsInner[0], { scale: 1, opacity: 1, duration: 0.5, ease: "back.out(2)" }, "intro+=1");

    tl.fromTo(node0Card,
      { opacity: 0, y: 100, rotationX: 15, scale: 0.95 },
      { opacity: 1, y: 0, rotationX: 0, scale: 1, duration: 1.5, ease: "power3.out" },
      "intro+=1"
    );
    tl.fromTo(node0Elems,
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, stagger: 0.05, duration: 0.8, ease: "back.out(1.5)" },
      "intro+=1.2"
    );

    tl.addLabel("node-0");

    // Loop through remaining nodes
    for (let i = 1; i < nodes.length; i++) {
      const prevCard = nodes[i - 1].querySelector('.node-card');
      const currCard = nodes[i].querySelector('.node-card');
      const currElems = nodes[i].querySelectorAll('.node-date, .node-metric, .node-title, .node-company, .node-desc, .node-skills span');
      
      const startTime = `node-${i - 1}`;
      
      // Move map
      tl.to(mapLayer, {
        y: `-${i * 100}vh`,
        duration: 3,
        ease: "power1.inOut"
      }, startTime);
      
      // Draw cable
      tl.to(activeCable, {
        height: `${i * 100}vh`,
        duration: 3,
        ease: "power1.inOut"
      }, startTime);

      // Rotate geometric patterns per node transition
      if (geoPattern1) {
        tl.to(geoPattern1, {
          rotation: `+=${6}`,
          scale: 1 + (i % 2 === 0 ? 0.02 : -0.02),
          duration: 3,
          ease: "power1.inOut"
        }, startTime);
      }
      if (geoPattern2) {
        tl.to(geoPattern2, {
          rotation: `-=${4}`,
          duration: 3,
          ease: "power1.inOut"
        }, startTime);
      }
      if (geoPattern3) {
        tl.to(geoPattern3, {
          rotation: `+=${2}`,
          x: `+=${i % 2 === 0 ? 15 : -15}`,
          duration: 3,
          ease: "power1.inOut"
        }, startTime);
      }

      // Fade out prev node
      tl.to(prevCard, {
        opacity: 0,
        y: -100,
        scale: 0.9,
        rotationX: -15,
        duration: 1.5,
        ease: "power2.in"
      }, `${startTime}+=0.2`);
      
      // Dim prev dot
      tl.to(dotsInner[i - 1], {
        scale: 0, opacity: 0, duration: 0.5
      }, `${startTime}+=0.5`);
      tl.to(dots[i - 1], {
        borderColor: "rgba(255,255,255,0.2)", duration: 0.5
      }, `${startTime}+=0.5`);

      // Light up current dot
      tl.to(dots[i], { borderColor: "#ededed", duration: 0.5 }, `${startTime}+=2.2`);
      tl.to(dotsInner[i], { scale: 1, opacity: 1, duration: 0.5, ease: "back.out(2)" }, `${startTime}+=2.2`);

      // Fade in current node
      tl.fromTo(currCard,
        { opacity: 0, y: 100, rotationX: 15, scale: 0.95 },
        { opacity: 1, y: 0, rotationX: 0, scale: 1, duration: 1.5, ease: "power3.out" },
        `${startTime}+=2.2`
      );
      
      tl.fromTo(currElems,
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, stagger: 0.05, duration: 0.8, ease: "back.out(1.5)" },
        `${startTime}+=2.4`
      );
      
      tl.addLabel(`node-${i}`);
    }

    // Outro
    tl.to(cameraWrapper, {
      rotationX: 45,
      scale: 0.7,
      opacity: 0,
      y: -100,
      duration: 2,
      ease: "power2.in"
    }, `node-${nodes.length - 1}+=1`);
  };

  document.addEventListener("astro:page-load", initExperience);
  if (document.readyState === "complete") {
    initExperience();
  } else {
    document.addEventListener("DOMContentLoaded", initExperience);
  }
</script>
